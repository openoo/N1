# 语法提示：按 OpenWrt 配置文件处理
#
# AW1000 NSS Lite 种子配置。
# 基础来自 qosmio/openwrt-ipq 的 nss-setup/config-nss.seed。
# 本文件只面向 Arcadyan AW1000，删除了其他设备和 IPQ60xx 未测试设备列表。
# 使用方法：复制为源码根目录 .config，然后执行 make defconfig V=s 自动补齐依赖。

#####################################################################
# 目标平台和设备
#####################################################################
# AW1000 属于 Qualcomm qualcommax/ipq807x 平台。
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq807x=y
CONFIG_TARGET_qualcommax_ipq807x_DEVICE_arcadyan_aw1000=y

#####################################################################
# NSS 加速
#####################################################################
# qca-nss-drv、qca-nss-ecm、bridge-mgr、vlan-mgr 通常由目标平台自动选择。
# 这里保留 config-nss.seed 中显式开启的 NSS 能力。

# NSS Mesh 支持，仅适合 NSS 固件 11.4；保留上游 seed 默认值。
CONFIG_ATH11K_NSS_MESH_SUPPORT=y

# QCA 组播监听，供 ECM/NSS 处理组播相关流量。
CONFIG_PACKAGE_kmod-qca-mcs=y

# NSS 版 SQM，用 NSS 路径做流量整形。
CONFIG_PACKAGE_sqm-scripts-nss=y

# AW1000 内置蜂窝模组走 QMI/RAWIP，ECM 会用到 RMNET 导出符号。
# 没有此项时，qca-nss-ecm 可能报 nss_rmnet_rx_get_ifnum 未定义。
CONFIG_NSS_DRV_RMNET_ENABLE=y

#####################################################################
# 编译优化
#####################################################################
# 启用 ccache 和开发选项，便于重复编译和自定义工具链参数。
CONFIG_CCACHE=y
CONFIG_DEVEL=y
CONFIG_EXPERIMENTAL=y
CONFIG_TOOLCHAINOPTS=y
CONFIG_TARGET_OPTIONS=y
CONFIG_TARGET_OPTIMIZATION="-O2 -pipe -mcpu=cortex-a53+crc+crypto"
CONFIG_USE_GC_SECTIONS=y

# 内核性能计数、动态调试和崩溃排查能力，沿用上游 seed。
CONFIG_COLLECT_KERNEL_DEBUG=y
CONFIG_KERNEL_PERF_EVENTS=y
CONFIG_KERNEL_DYNAMIC_DEBUG=y
CONFIG_KERNEL_ARM_PMU=y
CONFIG_KERNEL_PREEMPT_NONE=y
CONFIG_KERNEL_PREEMPT_NONE_BUILD=y

# 关闭 ath11k 额外调试和温控项，减小模块体积并对齐 qosmio seed。
CONFIG_ATH11K_DEBUGFS_HTT_STATS=n
CONFIG_ATH11K_DEBUGFS_STA=n
CONFIG_ATH11K_THERMAL=n

#####################################################################
# 加密库和无线
#####################################################################
# 统一使用 OpenSSL，避免和 mbedTLS 版本混用。
CONFIG_PACKAGE_libustream-openssl=y
CONFIG_PACKAGE_libustream-mbedtls=n
CONFIG_PACKAGE_libopenssl=y
CONFIG_LUA_ECO_OPENSSL=y
CONFIG_LUA_ECO_MBEDTLS=n
CONFIG_OPENSSL_OPTIMIZE_SPEED=y

# 启用 WPA3/Mesh 所需的 wpad OpenSSL 版本。
CONFIG_PACKAGE_wpad-mesh-openssl=y
CONFIG_PACKAGE_wpad-basic-mbedtls=n

# 压缩库优先性能。
CONFIG_ZLIB_OPTIMIZE_SPEED=y
CONFIG_ZSTD_OPTIMIZE_O3=y

# 不把编译期专用 feed 写进固件 opkg 源，避免运行时更新报不存在。
CONFIG_FEED_nss_packages=n
CONFIG_FEED_sqm_scripts_nss=n

#####################################################################
# LuCI 后台和中文支持
#####################################################################
# LuCI 基础后台、HTTPS 后台、防火墙页面和软件包管理页面。
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl-openssl=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-package-manager=y
CONFIG_LUCI_LANG_zh_Hans=y

#####################################################################
# 上游 seed 保留的常用页面和工具
#####################################################################
# iperf3 用于测速和 NSS/WiFi 性能验证。
CONFIG_PACKAGE_iperf3=y

# SQM、统计、证书、Watchcat、WireGuard、流量统计页面。
CONFIG_PACKAGE_luci-app-sqm=y
CONFIG_PACKAGE_luci-app-statistics=y
CONFIG_PACKAGE_luci-app-acme=y
CONFIG_PACKAGE_luci-app-watchcat=y
CONFIG_PACKAGE_luci-proto-wireguard=y
CONFIG_PACKAGE_luci-app-nlbwmon=y

# 文件系统、nft bridge、USB 存储和 ramoops 沿用 config-nss.seed。
# 如果后续要更轻，可以再单独去掉 USB 存储和文件系统项。
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_kmod-nft-bridge=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-ramoops=y

# 常用命令行工具。
CONFIG_PACKAGE_curl=y
CONFIG_LIBCURL_OPENSSL=y
CONFIG_LIBCURL_MBEDTLS=n
CONFIG_PACKAGE_rsync=y
CONFIG_PACKAGE_jq=y
CONFIG_PACKAGE_pigz=y
CONFIG_PACKAGE_tar=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_htop=y
CONFIG_HTOP_LMSENSORS=n

#####################################################################
# diy.sh 自定义主题
#####################################################################
# diy.sh 会拉取 jerrykuku 的 Argon 主题和配置页面。
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y

#####################################################################
# diy.sh 自定义包：PassWall
#####################################################################
# diy.sh 会替换 Go 工具链，并拉取 PassWall 官方包仓库。
# 这里保留 Xray 和 Hysteria 两个核心，关闭不用的旧协议核心以减少下载和编译风险。
# PassWall 需要 dnsmasq-full 的高级解析能力；基础 dnsmasq 与 dnsmasq-full 安装同名文件，必须显式关闭基础版。
CONFIG_PACKAGE_dnsmasq=n
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dnsmasq_full_dhcp=y
CONFIG_PACKAGE_dnsmasq_full_dhcpv6=y
CONFIG_PACKAGE_dnsmasq_full_ipset=y
CONFIG_PACKAGE_luci-app-passwall=y

# 使用 OpenWrt 24.10 的 firewall4/nftables 路线，避免再拉入旧 iptables 透明代理链路。
CONFIG_PACKAGE_luci-app-passwall_Iptables_Transparent_Proxy=n
CONFIG_PACKAGE_luci-app-passwall_Nftables_Transparent_Proxy=y

# 保留 Xray、Hysteria 和 Geoview；Geoview 用于规则和分流数据处理。
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Hysteria=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Geoview=y

# 关闭未计划使用的核心和插件，防止 aarch64 默认值自动拉入 SingBox、HAProxy、SSR、SS 插件等额外编译目标。
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_SingBox=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Haproxy=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_NaiveProxy=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Rust_Client=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Rust_Server=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_ShadowsocksR_Libev_Client=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_ShadowsocksR_Libev_Server=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadow_TLS=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Simple_Obfs=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_V2ray_Geodata=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_V2ray_Plugin=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray_Plugin=n

#####################################################################
# diy.sh 自定义包：AW1000 和蜂窝网络页面
#####################################################################
# 4IceG/nooblk-98 这些页面共用 sms-tool 和 comgt 访问 AT 口、短信和蜂窝信息。
# 虽然 LuCI 包的 Makefile 会自动选择依赖，这里显式保留运行时工具，便于审计并避免依赖解析异常。
CONFIG_PACKAGE_sms-tool=y
CONFIG_PACKAGE_comgt=y

# AW1000 LED 控制页面。
CONFIG_PACKAGE_luci-app-aw1k-led=y

# 3ginfo-lite 显示蜂窝信号状态，依赖 sms-tool、comgt 和 USB 串口 option 驱动。
CONFIG_PACKAGE_luci-app-3ginfo-lite=y

# modemband 用于频段选择/锁频；后端来自 obsy/modemband。
# USB 串口和 option 驱动用于生成 /dev/ttyUSB* AT 口，供 modemband、sms-tool 和 LED 状态脚本访问模组。
CONFIG_PACKAGE_kmod-usb-serial=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_modemband=y
CONFIG_PACKAGE_luci-app-modemband=y

# atinout 用于发送 AT 指令；4IceG 仓库同时提供 LuCI 页面和 atinout 命令行后端。
CONFIG_PACKAGE_atinout=y
CONFIG_PACKAGE_luci-app-atinout=y

# sms-tool-js 是独立短信页面，复用上面的 sms-tool、comgt 和 USB 串口驱动。
CONFIG_PACKAGE_luci-app-sms-tool-js=y

# qfirehose 用于 Quectel 等高通平台模组固件刷写；README 要求 luci-base、cgi-io、qfirehose、sms-tool。
# luci-base 已由 LuCI 后台选择，这里显式保留 cgi-io 和 qfirehose 后端。
CONFIG_PACKAGE_cgi-io=y
CONFIG_PACKAGE_qfirehose=y
CONFIG_PACKAGE_luci-app-qfirehose=y

# modemdata 显示模组数据；后端来自 obsy/modemdata。
CONFIG_PACKAGE_modemdata=y
CONFIG_PACKAGE_luci-app-modemdata=y

#####################################################################
# diy.sh 自定义包：QModem
#####################################################################
# luci-app-qmodem-next 是新版 QModem 页面，会依赖 qmodem 和 sms-forwarder-next。
# qmodem 会依赖 tom_modem、ubus-at-daemon、sms-tool_q、jq、bc、usbutils 和多种模组驱动。
CONFIG_PACKAGE_luci-app-qmodem-next=y

# AW1000 使用 Quectel 5G 模组，选择 Tom 定制版 Quectel-CM。
# quectel-CM-5G-M 会由下面的 QModem 选择项自动补齐。
CONFIG_PACKAGE_luci-app-qmodem_USE_TOM_CUSTOMIZED_QUECTEL_CM=y

# 选择厂商 QMI WWAN 驱动；qmi_wwan_q/f/s 由此项自动补齐。
# 不启用 PCIe MHI、MTK T7XX、QFirehose 等其他模组路线。
CONFIG_PACKAGE_luci-app-qmodem_INCLUDE_vendor-qmi-wwan=y
CONFIG_PACKAGE_luci-app-qmodem_INCLUDE_no_ndisc_rdisc6=y
CONFIG_PACKAGE_luci-app-qmodem_INCLUDE_ADD_PCI_SUPPORT=n
CONFIG_PACKAGE_luci-app-qmodem_INCLUDE_ADD_MTK_T7XX_SUPPORT=n
CONFIG_PACKAGE_luci-app-qmodem_INCLUDE_ADD_QFIREHOSE_SUPPORT=n

#####################################################################
# USB 共享网络
#####################################################################
# 对应 files/etc/uci-defaults/99-aw1000-usb-tether，把 usb0 自动作为 WAN 上游。
# RNDIS/CDC Ethernet 用于安卓或普通 USB 网卡，ipheth/usbmuxd/libimobiledevice 用于 iPhone USB 共享。
CONFIG_PACKAGE_kmod-usb-net=m
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=m
CONFIG_PACKAGE_kmod-usb-net-rndis=m
CONFIG_PACKAGE_kmod-usb-net-ipheth=m
CONFIG_PACKAGE_usbmuxd=y
CONFIG_PACKAGE_libimobiledevice=y
CONFIG_PACKAGE_libimobiledevice-utils=y

#####################################################################
# diy.sh 自定义包：状态页、内存释放、流量统计和应用过滤
#####################################################################
# autocore 和 arwi-dashboard 提供首页/状态增强；ramfree 提供内存释放页面。
CONFIG_PACKAGE_autocore=y
CONFIG_PACKAGE_luci-app-arwi-dashboard=y
CONFIG_PACKAGE_luci-app-ramfree=y

# bandix 提供流量统计页面，后端 bandix 由页面依赖自动补齐。
CONFIG_PACKAGE_luci-app-bandix=y

# OpenAppFilter 提供应用过滤，LuCI 页面依赖 appfilter 和 kmod-oaf。
CONFIG_PACKAGE_luci-app-oaf=y
